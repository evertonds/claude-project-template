{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "command": "echo '⚠️  File edited. Run tests if applicable.'"
      }
    ]
  },
  "permissions": {
    "allow": [],
    "deny": [
      "Bash(rm -rf *)",
      "Bash(DROP TABLE*)",
      "Bash(DELETE FROM*)"
    ]
  }
}
